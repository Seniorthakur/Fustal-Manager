# Production environment variables for Railway/Render/other Node hosting
# Use a real PostgreSQL connection string. Example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/futsal?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/futsal?schema=public"

# Use your deployed app URL. Example: https://your-app.up.railway.app
NEXTAUTH_URL=https://your-production-domain.com
APP_URL=https://your-production-domain.com

# Generate a strong secret:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Seed credentials. Change before production use.
SEED_SUPER_ADMIN_NAME=Owner
SEED_SUPER_ADMIN_USERNAME=owner
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!

# Hide demo credentials in production.
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false

# Dev-only LAN origins. Leave blank in production unless needed for local testing.
NEXT_ALLOWED_DEV_ORIGINS=
