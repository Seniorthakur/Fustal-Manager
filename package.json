{
  "name": "futsal-booking-admin",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prisma-generate-with-env.cjs && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "node scripts/prisma-generate-with-env.cjs",
    "db:push": "npm run env:ensure && prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run db:prepare",
    "seed": "npm run db:seed",
    "postinstall": "node scripts/prisma-generate-with-env.cjs",
    "dev:lan": "next dev -H 0.0.0.0",
    "predev": "npm run db:prepare",
    "predev:lan": "npm run db:prepare",
    "db:prepare": "node scripts/ensure-env.cjs && tsx scripts/ensure-data-dir.ts && prisma generate && prisma db push && tsx prisma/seed.ts",
    "db:reset": "node scripts/ensure-env.cjs && tsx scripts/ensure-data-dir.ts && prisma generate && prisma db push --force-reset && SEED_RESET=true tsx prisma/seed.ts",
    "env:ensure": "node scripts/ensure-env.cjs",
    "db:deploy": "node scripts/railway-deploy.cjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@tanstack/react-query": "^5.59.20",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.468.0",
    "next": "^15.3.0",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "recharts": "^2.15.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.19.0 <23"
  }
}
